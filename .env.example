# Slack Incoming Webhook URL used by the Contact Us form to post submissions.
# This is a SECRET: it is read only in server code (src/lib/slack.ts via the
# /api/contact route), is never prefixed NEXT_PUBLIC_, and is never sent to the
# browser or logged. Copy this file to `.env` and fill in a real webhook URL.
# Next.js auto-loads `.env` for `next dev` / `next build` / `next start`.
SLACK_URL=https://hooks.slack.com/services/XXXX/YYYY/ZZZZ
