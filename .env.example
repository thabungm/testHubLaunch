# Slack Incoming Webhook URL used by the Contact form to post notifications.
# This is a SECRET: it is read only in server code and is never sent to the
# browser or logged. Next.js auto-loads `.env` for dev/build/start.
#
# Copy this file to `.env` and set a real webhook URL:
#   SLACK_URL=https://hooks.slack.com/services/XXXX/YYYY/ZZZZ
SLACK_URL=
