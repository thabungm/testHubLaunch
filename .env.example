# Slack Incoming Webhook URL used by the Contact form to post submissions.
# This is a SECRET. It is read only in server code (src/lib/slack.ts, invoked by
# the /api/contact Route Handler), is never prefixed NEXT_PUBLIC_, and is never
# sent to the browser or logged. Next.js auto-loads .env for dev/build/start.
#
# Get one from: https://api.slack.com/messaging/webhooks
SLACK_URL=https://hooks.slack.com/services/XXXX/YYYY/ZZZZ
