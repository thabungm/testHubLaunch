# Slack Incoming Webhook URL used by the Contact Us form to post submissions.
# This is a SECRET: it is read only in server code (src/lib/slack.ts), is never
# prefixed NEXT_PUBLIC_, is never sent to the browser, and is never logged.
# Next.js auto-loads .env for `next dev` / `next build` / `next start`.
#
# Copy this file to .env and set a real webhook URL:
#   cp .env.example .env
SLACK_URL=https://hooks.slack.com/services/XXXX/YYYY/ZZZZ
