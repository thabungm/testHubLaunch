# Slack Incoming Webhook URL used to deliver contact-form submissions.
# This is a SECRET and is read server-side only (never exposed to the browser).
# Do NOT prefix with NEXT_PUBLIC_. Copy this file to `.env` and fill in a real value.
#
# Get one at: https://api.slack.com/messaging/webhooks
SLACK_URL=https://hooks.slack.com/services/XXXX/YYYY/ZZZZ
